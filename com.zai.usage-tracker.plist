<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zai.usage-tracker</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_DIR__/build/ZaiUsageTracker</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/zai-usage-tracker.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/zai-usage-tracker.log</string>
</dict>
</plist>
